# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend — payment receipt emails when admin marks a session PAID (optional in dev)
RESEND_API_KEY=
RESEND_FROM_EMAIL=receipts@yourdomain.com

# Paystack — Nigerian bank list for tutor payout settings (secret key, server-only)
PAYSTACK_SECRET_KEY=
